QUAKEWORLD_HUB_API_URL=https://<url>/rest/v1/<table>
QUAKEWORLD_HUB_API_ANON_KEY=<your-qw-hub-anon-key>

# Docker: use the mvd-api service name on the shared web network
# Local dev: use http://localhost:7890
MVD_API_URL=http://mvd-api:8080

PORT=3001

# Base path served under — must match handle_path in Caddy (default: /mvd_aggregator/)
VITE_BASE_PATH=/mvd_aggregator/
